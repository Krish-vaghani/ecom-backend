{
  "info": {
    "name": "Ecommerce API",
    "description": "Full API collection for ecom-backend: v1 (customer) and admin endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health",
        "description": "Check API is running."
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register or Request OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register-or-login",
            "description": "New user: register and send OTP. Existing: send OTP. Phone required; name required."
          }
        },
        {
          "name": "Login (Verify OTP)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\",\n  \"cartItems\": [{ \"productId\": \"\", \"quantity\": 1 }],\n  \"wishlist\": []\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Verify OTP; returns JWT. Optional: cartItems, wishlist to merge with user."
          }
        }
      ]
    },
    {
      "name": "Product",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/product/list?page=1&limit=10&category=jwellery&tag=bestseller",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "product", "list"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "category", "value": "jwellery", "description": "jwellery | purse" },
                { "key": "tag", "value": "bestseller", "description": "bestseller | hot | trending | sale" },
                {
                  "key": "landingSection",
                  "value": "best_collections",
                  "disabled": true,
                  "description": "hero | best_collections | elevate_look | fresh_styles"
                }
              ]
            }
          }
        },
        {
          "name": "Get Product Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/product/detail/:id?reviewPage=1&reviewLimit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "product", "detail", ":id"],
              "variable": [{ "key": "id", "value": "" }],
              "query": [
                { "key": "reviewPage", "value": "1" },
                { "key": "reviewLimit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Increment Product View",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/product/:id/view",
            "description": "Call when user views product detail. Path :id = productId."
          }
        }
      ]
    },
    {
      "name": "Landing",
      "item": [
        {
          "name": "Get All Landing Data",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/landing"
          }
        }
      ]
    },
    {
      "name": "Testimonial",
      "item": [
        {
          "name": "List Active Testimonials",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/testimonial/list"
          }
        }
      ]
    },
    {
      "name": "Address",
      "item": [
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address_type\": \"Home\",\n  \"full_name\": \"John Doe\",\n  \"mobile_number\": \"9876543210\",\n  \"email_address\": \"john@example.com\",\n  \"address_line_1\": \"123 Main St\",\n  \"address_line_2\": \"Apt 4\",\n  \"pincode\": \"110001\",\n  \"city\": \"New Delhi\",\n  \"state\": \"Delhi\",\n  \"landmark\": \"Near park\",\n  \"is_default\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/address/add",
            "description": "address_type: Home | Office | Other"
          }
        },
        {
          "name": "List Addresses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/address/list?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "address", "list"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Address",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/address/:id"
          }
        },
        {
          "name": "Update Address",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Doe\",\n  \"pincode\": \"110002\",\n  \"is_default\": true\n}"
            },
            "url": "{{baseUrl}}/api/v1/address/update/:id"
          }
        },
        {
          "name": "Delete Address",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/address/delete/:id"
          }
        }
      ]
    },
    {
      "name": "Cart",
