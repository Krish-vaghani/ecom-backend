            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/cart/remove"
          }
        },
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/cart"
          }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/wishlist/add"
          }
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/wishlist/remove"
          }
        },
        {
          "name": "List Wishlist",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/wishlist"
          }
        },
        {
          "name": "Check Wishlist",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/wishlist/check/:productId"
          }
        }
      ]
    },
    {
      "name": "Order",
      "item": [
        {
          "name": "Place Order (COD)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addressId\": \"\",\n  \"items\": [\n    { \"productId\": \"\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/order/place"
          }
        },
        {
          "name": "Create Razorpay Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addressId\": \"\",\n  \"items\": [\n    { \"productId\": \"\", \"quantity\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/api/v1/order/create-razorpay-order"
          }
        },
        {
          "name": "Verify Razorpay Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"\",\n  \"razorpay_order_id\": \"\",\n  \"razorpay_payment_id\": \"\",\n  \"razorpay_signature\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/order/verify-razorpay-payment"
          }
        },
        {
          "name": "List My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/order/list?page=1&limit=10&status=order_placed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "order", "list"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "order_placed" }
              ]
            }
          }
        },
        {
          "name": "Get Order Details",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/order/:id"
          }
        }
      ]
    },
    {
      "name": "Shipping",
      "item": [
        {
          "name": "Check Serviceability",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/shipping/check?pincode=110001&weight=0.5&cod=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "shipping", "check"],
              "query": [
                { "key": "pincode", "value": "110001" },
                { "key": "weight", "value": "0.5" },
                { "key": "cod", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Track Shipment",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/shipping/track/:awbOrOrderId",
            "description": "Pass AWB code or order ID"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Admin Auth",
          "item": [
            {
              "name": "Admin Login",
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"yourpassword\"\n}"
                },
                "url": "{{baseUrl}}/api/admin/auth/login",
                "description": "Returns admin token. Use in Authorization: Bearer {{adminToken}} for other admin requests."
              }
            }
          ]
        },
        {
          "name": "Admin Upload",
          "item": [
            {
              "name": "Upload Image",
              "request": {
                "method": "POST",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "image", "type": "file", "src": "", "description": "Image file" }
                  ]
                },
                "url": "{{baseUrl}}/api/admin/upload/image",
                "description": "Field name must be 'image'. S3 upload."
              }
            }
          ]
        },
        {
          "name": "Admin Product",
          "item": [
            {
              "name": "List Products",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": {
                  "raw": "{{baseUrl}}/api/admin/product/list?page=1&limit=10&landingSection=best_collections",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "admin", "product", "list"],
                  "query": [
                    { "key": "page", "value": "1" },
                    { "key": "limit", "value": "10" },
                    {
                      "key": "landingSection",
                      "value": "best_collections",
                      "disabled": true,
                      "description": "hero | best_collections | elevate_look | fresh_styles"
                    },
                    {
                      "key": "is_active",
                      "value": "true",
                      "disabled": true,
                      "description": "true | false"
                    }
                  ]
                },
                "description": "Admin list shows all products (active + inactive). Supports category/tag/landingSection/is_active filters."
              }
            },
            {
              "name": "Add Product",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Product Name\",\n  \"slug\": \"product-slug\",\n  \"description\": \"\",\n  \"price\": 999,\n  \"salePrice\": null,\n  \"category\": \"jwellery\",\n  \"image\": null,\n  \"landingSection\": null,\n  \"tags\": [\"bestseller\"],\n  \"colorVariants\": [],\n  \"shortDescription\": \"\",\n  \"dimensions\": { \"heightCm\": 10, \"widthCm\": 5, \"depthCm\": 2 },\n  \"averageRating\": 0,\n  \"numberOfReviews\": 0,\n  \"isFeatured\": false,\n  \"is_active\": true\n}"
                },
                "url": "{{baseUrl}}/api/admin/product/add",
                "description": "category: jwellery | purse; tags: bestseller | hot | trending | sale"
              }
            },
            {
              "name": "Update Product",
              "request": {
                "method": "PUT",
                "header": [
                  { "key": "Content-Type", "value": "application/json" },
                  { "key": "Authorization", "value": "Bearer {{adminToken}}" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Name\",\n  \"price\": 899,\n  \"landingSection\": \"best_collections\"\n}"
                },
                "url": "{{baseUrl}}/api/admin/product/update/:id"
              }
            },
            {
              "name": "Delete Product",
              "request": {
                "method": "DELETE",
                "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
                "url": "{{baseUrl}}/api/admin/product/delete/:id",
                "description": "Soft delete (is_active: false)"
              }
            }
          ]
        },
        {
          "name": "Admin Testimonial",
