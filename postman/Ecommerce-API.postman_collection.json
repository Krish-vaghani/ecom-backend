            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"\",\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/api/v1/cart/update"
          }
        },
        {
          "name": "Remove from Cart",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
